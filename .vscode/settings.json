{
  "files.associations": {
    "*.njk": "nunjucks"
  },
  "emmet.includeLanguages": {
    "njk": "html",
    "nunjucks": "html"
  },
  "emmet.triggerExpansionOnTab": true,
  "github.copilot.enable": {
    "*": false
  },
  "github.copilot.editor.enableAutoCompletions": false,
  "editor.inlineSuggest.enabled": false
}
