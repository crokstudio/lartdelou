---
permalink: contact.html
title: Contact
---

{% extends "layouts/base.njk" %}

{% block content %}
    {% set featuredFallback = collections.paintings[0] %}

    <section class="section contact">
        <article class="contact-featured" aria-label="Oeuvre mise en avant" data-contact-featured>
            <figure class="contact-featured--figure">
                <picture>
                    <img
                        src="{{ featuredFallback.data.image }}"
                        alt="{{ featuredFallback.data.title }}"
                        sizes="(max-width: 1023px) 100vw, 32vw"
                        loading="eager"
                        decoding="async"
                        class="contact-featured--image"
                        data-contact-featured-image
                    >
                </picture>
                <figcaption class="contact-featured--caption">
                    <div>
                        <h2 data-contact-featured-title>{{ featuredFallback.data.title }}</h2>
                        <p data-contact-featured-year>{{ featuredFallback.data.date | year }}</p>
                    </div>
                    <div>
                        <p data-contact-featured-type>{{ featuredFallback.data.type }}</p>
                        <p data-contact-featured-dimensions>{{ featuredFallback.data.dimensions.x }} x {{ featuredFallback.data.dimensions.y }}</p>
                    </div>
                </figcaption>
            </figure>
        </article>

        <script type="application/json" data-contact-artworks>
            [
                {% for artwork in collections.paintings %}
                    {
                        "title": {{ artwork.data.title | json | safe }},
                        "year": {{ artwork.data.date | year | json | safe }},
                        "type": {{ artwork.data.type | json | safe }},
                        "image": {{ artwork.data.image | json | safe }},
                        "dimensions": {{ (artwork.data.dimensions.x ~ " x " ~ artwork.data.dimensions.y) | json | safe }}
                    }{% if not loop.last or collections.sculptures.length %},{% endif %}
                {% endfor %}
                {% for artwork in collections.sculptures %}
                    {
                        "title": {{ artwork.data.title | json | safe }},
                        "year": {{ artwork.data.date | year | json | safe }},
                        "type": {{ artwork.data.type | json | safe }},
                        "image": {{ artwork.data.image | json | safe }},
                        "dimensions": {{ (artwork.data.dimensions.x ~ " x " ~ artwork.data.dimensions.y) | json | safe }}
                    }{% if not loop.last %},{% endif %}
                {% endfor %}
            ]
        </script>

        <div class="contact--divider" aria-hidden="true"></div>

        <article class="contact-content">
            
            <h1>Contactez-moi</h1>
            <div class="contact-content--intro">
                <div class="contact-content--details">
                    <h3>L&rsquo;art de Lou</h3>
                    <h4>BELGIQUE</h4>
                    <h4><a href="mailto:lou@lartdelou.be">lou@lartdelou.be</a></h4>
                </div>
            </div>

            <form class="contact-form" name="contact" method="POST" action="/merci/" data-netlify="true" netlify-honeypot="bot-field">
                <input type="hidden" name="form-name" value="contact">
                <p class="contact-form--hidden">
                    <label>Ne pas remplir <input name="bot-field"></label>
                </p>
                <label class="contact-form--field">
                    <span>Nom</span>
                    <input type="text" name="nom" autocomplete="family-name" required>
                </label>

                <label class="contact-form--field">
                    <span>Prénom</span>
                    <input type="text" name="prenom" autocomplete="given-name" required>
                </label>

                <label class="contact-form--field">
                    <span>Email</span>
                    <input type="email" name="email" autocomplete="email" required>
                </label>

                <label class="contact-form--field">
                    <span>Objet du mail</span>
                    <input type="text" name="objet" required>
                </label>

                <label class="contact-form--field contact-form--field-message">
                    <span>Message</span>
                    <textarea name="message" required></textarea>
                </label>
                <button class="contact-form--submit cta" type="submit">Envoyer</button>
            </form>
        </article>
    </section>

{% endblock %}
